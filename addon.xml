<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.nzbdavstreamer" name="NzbDAV Streamer" version="1.0.0" provider-name="Boss">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="main.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Direct NzbDAV streaming</summary>
    <description lang="en_GB">A custom add-on to stream instantly via NzbDAV.</description>
    <platform>all</platform>
  </extension>
</addon>